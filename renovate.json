{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests",
    ":semanticCommits"
  ],
  "timezone": "UTC",
  "schedule": [
    "after 10pm on friday"
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": [
      "after 10pm on friday"
    ]
  },
  "packageRules": [
    {
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "non-major dependencies"
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "github actions",
      "pinDigests": true
    }
  ]
}
